{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/common.finding.schema.json",
  "title": "Diagnostic Finding",
  "description": "A structured issue, warning, or repair note produced during sanitization or CSV conversion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "severity",
    "category",
    "line",
    "message"
  ],
  "properties": {
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "category": {
      "type": "string"
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "position": {
      "type": "integer",
      "minimum": 0
    },
    "message": {
      "type": "string"
    }
  }
}
